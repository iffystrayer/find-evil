# Copy to .env and fill in for a LIVE run against the SIFT VM.

# --- LLM ---
LLM_PROVIDER=ollama
LLM_MODEL=deepseek-v3.1
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Executor ---
# mock = replay fixtures (no SIFT). ssh = run on the SIFT VM over the LAN.
EXECUTOR=ssh

# --- SIFT Workstation over the LAN ---
SIFT_HOST=192.168.1.50
SIFT_PORT=22
SIFT_USER=sansforensics
SIFT_SSH_KEY_PATH=/home/you/.ssh/id_ed25519
# Password auth is supported as a fallback when key auth is not set up (for
# example the SANS SIFT default sansforensics/forensics). Key auth is preferred.
# SIFT_PASSWORD=forensics
# Leave known-hosts unset to use ~/.ssh/known_hosts. Keep strict checking on.
# Set false only for a first connect to a known LAN VM with no known_hosts entry.
SIFT_STRICT_HOST_KEY=true

# Evidence + workspace paths AS SEEN ON THE SIFT VM. Comma-separated allowlist.
EVIDENCE_ALLOWLIST=/mnt/evidence/,/cases/
WORKSPACE_DIR=/tmp/find-evil

# --- Budget ---
MAX_STEPS=12
MAX_WALL_SECONDS=1800

# --- Ledger ---
DB_PATH=./find_evil_runs.db
